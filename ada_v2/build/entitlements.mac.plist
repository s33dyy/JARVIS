<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  entitlements.mac.plist
  Required for macOS Hardened Runtime.
  Allows: microphone, camera, audio input, network client, dynamic libs, unsigned executables.
  Note: Code signing identity is NOT required for local distribution (GateKeeper bypass).
-->
<plist version="1.0">
<dict>
    <!-- Audio / Microphone access -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Camera access -->
    <key>com.apple.security.device.camera</key>
    <true/>
    <!-- Network client (API calls, WebSocket, Ollama) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Allow JIT (needed by some Python packages) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory (PyInstaller + some native libs) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow dyld env vars (needed for some bundled libs) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Disable library validation (lets PyInstaller load its bundled libs) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Files: read/write access for project files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
